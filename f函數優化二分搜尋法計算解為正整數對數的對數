        "import time\n",
        "import random\n",
        "\n",
        "def f_driven_binary_search_log(x, Y):\n",
        "    \"\"\"\n",
        "    基於論文 f 函數特徵定位與二分搜尋結合的對數演算法\n",
        "    \"\"\"\n",
        "    if Y == 1:\n",
        "        return 0\n",
        "    if Y < x:\n",
        "        return 0\n",
        "\n",
        "    # 1. 根據論文代換公式計算 R 與 f 函數\n",
        "    # R_n(x) = (Y - 1) // (x - 1)\n",
        "    R = (Y - 1) // (x - 1)\n",
        "    # f = R - (x - 1) * (R^2 // Y)\n",
        "    f = R - (x - 1) * ((R * R) // Y)\n",
        "\n",
        "    # 2. 根據定理：f = T(n-1, x-1) + 1  =>  n = q * (x - 1) + f\n",
        "    # 我們不再盲搜 n，而是二分搜尋商數 q\n",
        "\n",
        "    # 粗略估計 q 的最大上界 (利用位元長度)\n",
        "    approx_n = Y.bit_length() // x.bit_length() + 1\n",
        "    max_q = approx_n // (x - 1) + 1\n",
        "\n",
        "    low_q = 0\n",
        "    high_q = max_q\n",
        "    best_n = f\n",
        "\n",
        "    while low_q <= high_q:\n",
        "        mid_q = (low_q + high_q) // 2\n",
        "        # 還原出可能的 n\n",
        "        test_n = mid_q * (x - 1) + f\n",
        "\n",
        "        # 計算 x^test_n (Python 內建大數 pow 非常高效)\n",
        "        val = pow(x, test_n)\n",
        "\n",
        "        if val == Y:\n",
        "            return test_n\n",
        "        elif val < Y:\n",
        "            best_n = test_n\n",
        "            low_q = mid_q + 1  # 往更高的商數搜尋\n",
        "        else:\n",
        "            high_q = mid_q - 1 # 往更低的商數搜尋\n",
        "\n",
        "    return best_n\n",
        "\n",
        "def standard_binary_search_log(x, Y):\n",
        "    \"\"\"\n",
        "    傳統標準二分搜尋法\n",
        "    \"\"\"\n",
        "    low = 0\n",
        "    high = Y.bit_length()\n",
        "    ans = 0\n",
        "    while low <= high:\n",
        "        mid = (low + high) // 2\n",
        "        val = pow(x, mid)\n",
        "        if val == Y:\n",
        "            return mid\n",
        "        elif val < Y:\n",
        "            ans = mid\n",
        "            low = mid + 1\n",
        "        else:\n",
        "            high = mid - 1\n",
        "    return ans\n",
        "\n",
        "def bit_length_optimized_binary_search_log(x, Y):\n",
        "    \"\"\"\n",
        "    傳統大數在庫常用的位元長度逼近二分搜\n",
        "    \"\"\"\n",
        "    # 先用位元長度極度縮小搜尋區間\n",
        "    low = max(0, (Y.bit_length() - 1) // x.bit_length())\n",
        "    high = (Y.bit_length() // (x.bit_length() - 1)) + 1 if x > 2 else Y.bit_length()\n",
        "\n",
        "    ans = low\n",
        "    while low <= high:\n",
        "        mid = (low + high) // 2\n",
        "        val = pow(x, mid)\n",
        "        if val == Y:\n",
        "            return mid\n",
        "        elif val < Y:\n",
        "            ans = mid\n",
        "            low = mid + 1\n",
        "        else:\n",
        "            high = mid - 1\n",
        "    return ans\n",
        "\n",
        "# ==========================================\n",
        "# 測試與驗證效能\n",
        "# ==========================================\n",
        "if __name__ == \"__main__\":\n",
        "    print(\"====== 大數全域整數對數演算法性能測試 ======\")\n",
        "\n",
        "    # 構造一個巨大的測試案例\n",
        "    # 設定較大的基數 x，以及指數 n\n",
        "    x = 1234567\n",
        "    n = 98765\n",
        "    Y = pow(x, n)\n",
        "\n",
        "    print(f\"測試參數：基數 x = {x} (位元長度: {x.bit_length()})\")\n",
        "    print(f\"真實指數 n = {n}\")\n",
        "    print(f\"目標大數 Y 的位元長度: {Y.bit_length()} 位元\\n\")\n",
        "\n",
        "    # ---- 演算法 1: 傳統標準二分搜 ----\n",
        "    t0 = time.perf_counter()\n",
        "    res1 = standard_binary_search_log(x, Y)\n",
        "    t1 = time.perf_counter()\n",
        "    time_std = t1 - t0\n",
        "    print(f\"[1] 傳統標準二分搜       -> 結果: {res1}, 耗時: {time_std:.6f} 秒\")\n",
        "\n",
        "    # ---- 演算法 2: 位元長度優化二分搜 ----\n",
        "    t0 = time.perf_counter()\n",
        "    res2 = bit_length_optimized_binary_search_log(x, Y)\n",
        "    t1 = time.perf_counter()\n",
        "    time_opt = t1 - t0\n",
        "    print(f\"[2] 位元長度優化二分搜    -> 結果: {res2}, 耗時: {time_opt:.6f} 秒\")\n",
        "\n",
        "    # ---- 演算法 3: f 函數 + 二分搜 (我們的演算法) ----\n",
        "    t0 = time.perf_counter()\n",
        "    res3 = f_driven_binary_search_log(x, Y)\n",
        "    t1 = time.perf_counter()\n",
        "    time_f = t1 - t0\n",
        "    print(f\"[3] f函數特徵定位二分搜   -> 結果: {res3}, 耗時: {time_f:.6f} 秒\")\n",
        "\n",
        "    # ---- 正確性驗證 ----\n",
        "    assert res1 == n and res2 == n and res3 == n, \"錯誤：有演算法計算結果不正確！\"\n",
        "    print(\"\\n====== 結論 ======\")\n",
        "    print(\" 正確性驗證通過！三種演算法均精確求得 n。\")\n",
        "    print(f\" 我們的算法比 [傳統標準二分搜] 快了 {time_std / time_f:.2f} 倍\")\n",
        "    print(f\" 我們的算法比 [位元長度優化二分搜] 快了 {time_opt / time_f:.2f} 倍\")"
      ]
    }
